{
  "name": "opendeck-weather",
  "version": "1.9.0",
  "private": true,
  "description": "Live weather widget for OpenDeck powered by OpenWeatherMap",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "log": "tail -f \"$HOME/.config/opendeck/plugins/com.plungarini.weather.sdPlugin/plugin.log\"",
    "sync": "rsync -a --delete --exclude=node_modules --exclude=plugin.log --exclude=.git ./ \"$HOME/.config/opendeck/plugins/com.plungarini.weather.sdPlugin/\"",
    "clean": "rm -rf node_modules package-lock.json",
    "preinstall": "echo 'Run: npm install --ignore-scripts'"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.54",
    "ws": "^8.16.0"
  }
}
